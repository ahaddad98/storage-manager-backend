# Application
APP_NAME=ma-cabinet
APP_ENV=development
DEBUG=true
API_PREFIX=/api

# Server
HOST=0.0.0.0
PORT=8005

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ma_cabinet
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ma_cabinet

# JWT
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
